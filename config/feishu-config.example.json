    "events": {
      "skill_completed": true,
      "skill_failed": true,
      "login_expiring": true,
      "health_check_result": true,
      "task_analysis_completed": true
    }
  },
  "taskPilot": {
    "sources": {
      "git": true,
      "todoFiles": ["TODO.md"],
      "feishuTodoUrl": "",
      "grepPatterns": ["TODO", "FIXME"]
    },
    "autoNotify": true
  },
  "projects": {}
