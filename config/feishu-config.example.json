{
  "user": {
    "name": "your-username",
    "team": "your-team"
  },
  "feishu": {
    "defaultFolder": "",
    "wikiSpaceUrl": ""
  },
  "scaffold": {
    "defaultTemplate": "react-app",
    "packageManager": "pnpm"
  },
  "arch": {
    "adrDir": "./docs/adr"
  },
  "git": {
    "repos": []
  },
  "webhook": {
    "enabled": true,
    "defaultChannels": ["feishu"],
    "channels": {
      "feishu": {
        "webhookUrl": "https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id",
