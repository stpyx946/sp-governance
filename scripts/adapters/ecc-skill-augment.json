    },
    "sp-lint": {
      "ecc_skills": ["coding-standards"],
      "inject_as": "reference",
      "prompt_prefix": "代码规范参考:"
    },
    "sp-playwright": {
      "ecc_skills": ["e2e-testing"],
      "inject_as": "context",
      "prompt_prefix": "E2E 测试最佳实践:"
    }
